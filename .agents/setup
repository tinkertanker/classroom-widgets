#!/usr/bin/env bash
set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

if (( EUID == 0 )); then
  SUDO=()
else
  SUDO=(sudo)
fi

node_is_compatible() {
  command -v node >/dev/null 2>&1 &&
    node -e 'const [major, minor] = process.versions.node.split(".").map(Number); process.exit(major === 22 && minor >= 12 ? 0 : 1)'
}

if ! node_is_compatible; then
  echo "Installing Node.js 22..."
  "${SUDO[@]}" apt-get update
  "${SUDO[@]}" apt-get install -y ca-certificates curl gnupg
  curl -fsSL https://deb.nodesource.com/setup_22.x | "${SUDO[@]}" bash -
  "${SUDO[@]}" apt-get install -y nodejs
fi

if ! node_is_compatible && [[ -x /usr/bin/node ]] &&
  /usr/bin/node -e 'const [major, minor] = process.versions.node.split(".").map(Number); process.exit(major === 22 && minor >= 12 ? 0 : 1)'; then
  echo "Removing an older /usr/local Node.js shim from PATH..."
  "${SUDO[@]}" ln -sf /usr/bin/node /usr/local/bin/node
  hash -r
fi

if ! node_is_compatible; then
  echo "Node.js 22 installation did not become active." >&2
  exit 1
fi

echo "Using Node.js $(node --version) and npm $(npm --version)"

echo "Installing locked npm workspace dependencies..."
npm ci --legacy-peer-deps --no-audit --no-fund

echo "Orb setup complete."
