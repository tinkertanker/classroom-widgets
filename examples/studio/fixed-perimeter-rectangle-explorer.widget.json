{
  "schemaVersion": "1.0",
  "id": "fixed-perimeter-rectangle-explorer",
  "metadata": {
    "title": "Rectangles with the Same Perimeter",
    "summary": "Pupils change a target perimeter and explore the possible length-width pairs on a graph.",
    "subject": "mathematics",
    "level": "upper-primary",
    "locale": "en-SG",
    "learningObjective": "Generate different rectangles with the same perimeter and reason about the relationship between width and length.",
    "estimatedMinutes": 11,
    "tags": ["measurement", "perimeter", "rectangles", "graphs", "simulation"]
  },
  "theme": {
    "accent": "amber",
    "colourScheme": "light",
    "density": "comfortable"
  },
  "assets": [],
  "variables": [
    {
      "id": "target-perimeter",
      "kind": "number",
      "label": "Target perimeter",
      "initial": 24,
      "minimum": 12,
      "maximum": 40,
      "step": 2,
      "unit": "cm"
    }
  ],
  "screens": [
    {
      "id": "explore-pairs",
      "title": "Explore possible dimensions",
      "components": [
        {
          "id": "title",
          "kind": "text",
          "role": "title",
          "text": "How many rectangles can share one perimeter?"
        },
        {
          "id": "instructions",
          "kind": "text",
          "role": "instruction",
          "text": "Choose an even perimeter. The graph shows possible width-length pairs. Pick whole-number points and check that twice the width plus twice the length gives the target."
        },
        {
          "id": "perimeter-control",
          "kind": "numberControl",
          "variableId": "target-perimeter",
          "presentation": "stepper"
        },
        {
          "id": "side-total",
          "kind": "valueDisplay",
          "label": "Width plus length must equal",
          "expression": {
            "kind": "binary",
            "operator": "divide",
            "left": { "kind": "variable", "variableId": "target-perimeter" },
            "right": { "kind": "literal", "value": 2 }
          },
          "decimalPlaces": 0,
          "unit": "cm"
        },
        {
          "id": "dimension-plot",
          "kind": "plot",
          "title": "Possible width-length pairs",
          "description": "Each point on the line represents a rectangle whose width plus length is half the chosen perimeter.",
          "domain": {
            "variableId": "width-value",
            "label": "Width",
            "minimum": 1,
            "maximum": 19,
            "step": 0.25,
            "unit": "cm"
          },
          "range": {
            "label": "Length",
            "minimum": 0,
            "maximum": 20,
            "unit": "cm"
          },
          "series": [
            {
              "id": "possible-dimensions",
              "label": "length = perimeter ÷ 2 − width",
              "colour": "amber",
              "yExpression": {
                "kind": "binary",
                "operator": "subtract",
                "left": {
                  "kind": "binary",
                  "operator": "divide",
                  "left": { "kind": "variable", "variableId": "target-perimeter" },
                  "right": { "kind": "literal", "value": 2 }
                },
                "right": { "kind": "variable", "variableId": "width-value" }
              }
            }
          ],
          "showGrid": true,
          "showLegend": false
        },
        {
          "id": "perimeter-check",
          "kind": "choiceQuestion",
          "prompt": "Which equation always checks whether width w and length l match a chosen perimeter P?",
          "selectionMode": "single",
          "options": [
            { "id": "double-sum", "content": { "kind": "text", "text": "2 × (w + l) = P" } },
            { "id": "single-sum", "content": { "kind": "text", "text": "w + l = P" } },
            { "id": "double-product", "content": { "kind": "text", "text": "2 × w × l = P" } },
            { "id": "area-rule", "content": { "kind": "text", "text": "w × l = P" } }
          ],
          "correctOptionIds": ["double-sum"],
          "shuffleOptions": true,
          "feedback": {
            "correct": "Correct. A rectangle has two widths and two lengths, so its perimeter is twice their sum.",
            "incorrect": "Count both widths and both lengths around the rectangle.",
            "explanation": "The perimeter rule 2w + 2l = P can be factorised as 2 × (w + l) = P for every value of the control."
          }
        }
      ]
    }
  ]
}
