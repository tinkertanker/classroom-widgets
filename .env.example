# ===========================================
# Classroom Widgets - Development Environment
# ===========================================
# Copy this file to .env for local Docker Compose testing.
# For npm/Vite development, use packages/teacher/.env.example and
# packages/server/.env.example instead.
# Never commit .env files with real secrets!

# ============================================
# Frontend Configuration (Vite)
# ============================================

# Backend server URL (where Socket.io connects)
VITE_SERVER_URL=http://localhost:3001

# Short.io API Configuration (optional - for Link Shortener widget)
VITE_SHORTIO_API_KEY=
VITE_SHORTIO_BASE_URL=https://api.short.io/links/public
VITE_SHORTIO_DOMAIN=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

# Student app URL shown to teachers in local Docker testing
STUDENT_APP_URL=http://localhost:3000/student

# ============================================
# Umami Analytics (Privacy-focused)
# ============================================

# Umami tracking script URL (local Docker testing with `--profile analytics`)
VITE_UMAMI_SCRIPT_URL=http://localhost:3003/script.js

# Website ID (get this from Umami dashboard after creating a website)
# Leave empty to disable tracking
VITE_UMAMI_WEBSITE_ID=

# Umami app secret (for docker-compose)
UMAMI_APP_SECRET=replace-me-with-a-random-string

# ============================================
# Development Settings
# ============================================

# Enable debug mode (optional)
# VITE_DEBUG=true

# ============================================
# Notes for Different Environments
# ============================================

# For npm/Vite local development:
#   - Copy packages/teacher/.env.example to packages/teacher/.env
#   - Copy packages/server/.env.example to packages/server/.env if needed
#   - Update VITE_SHORTIO_API_KEY and VITE_SHORTIO_DOMAIN if using Link Shortener

# For Docker local testing:
#   - Copy to .env: cp .env.example .env
#   - Run: docker compose up --build
#   - Uses these default values
#   - Add --profile analytics to start Umami too

# For production deployment:
#   - See .env.production.example
#   - Never commit production .env files!
