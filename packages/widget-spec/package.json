{
  "name": "@classroom-widgets/widget-spec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema/v1": "./schema/widget-spec-v1.schema.json"
  },
  "files": [
    "src",
    "schema",
    "fixtures"
  ],
  "scripts": {
    "generate:validator": "node scripts/generate-validator.mjs",
    "pretest": "npm run generate:validator",
    "pretypecheck": "npm run generate:validator",
    "eval:corpus": "tsx ../../evals/widget-spec/run.ts",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
