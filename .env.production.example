# ===========================================
# Classroom Widgets - Production Environment
# ===========================================
# Copy this file to .env.production for deployment
# NEVER commit .env.production with real secrets!

# ============================================
# Frontend Configuration (Vite)
# ============================================

# Backend server URL (public HTTPS endpoint)
VITE_SERVER_URL=https://your-backend-domain.com

# Short.io API Configuration (optional)
VITE_SHORTIO_API_KEY=
VITE_SHORTIO_BASE_URL=https://api.short.io/links/public
VITE_SHORTIO_DOMAIN=

# ============================================
# Backend Configuration (for docker-compose)
# ============================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.com,https://your-backend-domain.com

# ============================================
# Public Domain Configuration
# ============================================

# Frontend domain used by your host Nginx/SSL configuration
FRONTEND_DOMAIN=your-frontend-domain.com

# Backend domain used by your host Nginx/SSL configuration
BACKEND_DOMAIN=your-backend-domain.com

# Student app URL shown to teachers. In production the backend serves it.
STUDENT_APP_URL=https://your-backend-domain.com/student

# ============================================
# Umami Analytics (Privacy-focused)
# ============================================

# Umami tracking script URL (optional; set only if using the analytics profile)
VITE_UMAMI_SCRIPT_URL=

# Website ID (get this from Umami dashboard after creating a website)
VITE_UMAMI_WEBSITE_ID=

# Umami domain if you proxy the optional analytics service
UMAMI_DOMAIN=your-umami-domain.com

# Umami database credentials (required only with `--profile analytics`; use strong passwords)
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=your-secure-password-here

# Umami app secret (required only with `--profile analytics`; generate with: openssl rand -base64 32)
UMAMI_APP_SECRET=your-secret-key-here

# ============================================
# Deployment Instructions
# ============================================

# 1. Copy this file: cp .env.production.example .env.production
# 2. Update all URLs and domains
# 3. Add real API keys
# 4. Ensure .env.production is in .gitignore
# 5. Deploy with: docker compose --env-file .env.production -f docker-compose.prod.yml up -d

# For secrets management in production:
# - Use Docker secrets
# - Or use environment variables from your CI/CD
# - Or use a secrets manager (AWS Secrets Manager, Vault, etc.)
